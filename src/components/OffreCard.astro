---
import PbImage from "./PbImage.astro";

const { offre } = Astro.props;
---

<div class="card">
    <h2>{offre.nomMaison}</h2>

    <PbImage record={offre} recordImage={offre.images[0]} />
    <PbImage record={offre} recordImage={offre.images[1]} />
    <PbImage record={offre} recordImage={offre.images[2]} />

    {offre.favori && <span class="favori">★ Favori</span>}
    <a href={`/offres/${offre.id}`}>Voir plus</a>
</div>